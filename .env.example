# Optional: OpenAI-kompatible LLM-Schnittstelle für semantische Bewertung.
# Ohne API-Key wird die regelbasierte (heuristische) Bewertung verwendet.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

STEPSTONE_BASE_URL=https://www.stepstone.de

# Suchpräferenzen (leer = neutral bewerten)
DEFAULT_LOCATION=
DEFAULT_RADIUS_KM=50
REMOTE_PREFERENCE=

ENABLE_HEADLESS=false
MAX_JOBS_PER_RUN=50
# Wartezeit zwischen Seitenaufrufen in Millisekunden (Rate Limiting)
REQUEST_DELAY_MS=4000

DATABASE_URL=./data/jobs.sqlite
CV_FILE_PATH=
